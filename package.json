{
  "name": "sp-search",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.14.0 < 23.0.0"
  },
  "main": "lib/index.js",
  "sideEffects": [
    "*.scss",
    "*.css",
    "**/node_modules/@pnp/**",
    "**/node_modules/spfx-toolkit/lib/utilities/context/pnpImports/**",
    "**/node_modules/spfx-toolkit/esm/utilities/context/pnpImports/**",
    "**/node_modules/devextreme/dist/css/**"
  ],
  "scripts": {
    "build": "heft build --clean",
    "build:ship": "heft build --clean --production",
    "start": "heft start --clean",
    "package": "heft build --clean --production && heft package-solution --production",
    "package:debug": "heft build --clean && heft package-solution",
    "clean": "heft clean",
    "clean:cache": "rimraf node_modules/.cache",
    "clean:all": "heft clean && rimraf release sharepoint/solution",
    "stats": "ANALYZE=1 heft build --clean --production",
    "stats:json": "heft build --clean --production --emit-stats",
    "type-check": "heft build --clean --lite",
    "test": "heft test",
    "test:watch": "heft test --watch",
    "test:coverage": "heft test --coverage"
  },
  "dependencies": {
    "@fluentui/react": "^8.106.4",
    "@microsoft/sp-component-base": "^1.22.2",
    "@microsoft/sp-core-library": "^1.22.2",
    "@microsoft/sp-http": "^1.22.2",
    "@microsoft/sp-lodash-subset": "^1.22.2",
    "@microsoft/sp-office-ui-fabric-core": "^1.22.2",
    "@microsoft/sp-property-pane": "^1.22.2",
    "@microsoft/sp-webpart-base": "^1.22.2",
    "@pnp/logging": "^4.16.0",
    "@pnp/queryable": "^3.20.1",
    "@pnp/sp": "^3.20.1",
    "@pnp/spfx-controls-react": "^3.22.0",
    "@pnp/spfx-property-controls": "^3.22.0",
    "devextreme": "^22.2.3",
    "devextreme-react": "^22.2.3",
    "react": "17.0.1",
    "react-dom": "17.0.1",
    "react-hook-form": "^7.45.4",
    "spfx-toolkit": "file:../spfx-toolkit",
    "tslib": "2.3.1",
    "xlsx": "^0.18.5",
    "zustand": "^4.3.9"
  },
  "devDependencies": {
    "@microsoft/sp-module-interfaces": "^1.22.2",
    "@microsoft/spfx-heft-plugins": "^1.22.2",
    "@microsoft/spfx-web-build-rig": "^1.22.2",
    "@rushstack/eslint-config": "^4.6.4",
    "@rushstack/heft": "^1.2.7",
    "@types/react": "17.0.45",
    "@types/react-dom": "17.0.17",
    "@types/webpack-env": "~1.15.2",
    "ajv": "^6.12.5",
    "css-loader": "^7.1.4",
    "eslint": "8.57.1",
    "eslint-plugin-react-hooks": "4.3.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-util": "^29.7.0",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.3.3",
    "webpack-bundle-analyzer": "4.10.2"
  }
}
