{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx/client-side-web-part-manifest.schema.json",
  "id": "d0481c49-49f9-4219-90fe-be8338051f58",
  "alias": "SpSearchVerticalsWebPart",
  "componentType": "WebPart",

  // The "*" signifies that the version should be taken from the package.json
  "version": "*",
  "manifestVersion": 2,

  // If true, the component can only be installed on sites where Custom Script is allowed.
  // Components that allow authors to embed arbitrary script code should set this to true.
  // https://support.office.com/en-us/article/Turn-scripting-capabilities-on-or-off-1f2c515f-5d7e-448a-9fd7-835da935584f
  "requiresCustomScript": false,
  "supportedHosts": ["SharePointWebPart", "TeamsPersonalApp", "TeamsTab", "SharePointFullPage"],
  "supportsThemeVariants": true,

  "preconfiguredEntries": [{
    "groupId": "5c03119e-3074-46fd-976b-c60198311f70",
    "group": { "default": "Advanced" },
    "title": { "default": "SP Search Verticals" },
    "description": { "default": "PnP-style starter verticals for All, Documents, Pages, and Sites" },
    "officeFabricIconFontName": "SortLines",
    "properties": {
      "searchContextId": "default",
      "verticals": "[]",
      "verticalsCollection": [
        {
          "uniqueId": "starter-vertical-0",
          "key": "all",
          "label": "All",
          "iconName": "Search",
          "queryTemplate": "{searchTerms}",
          "resultSourceId": "",
          "dataProviderId": "",
          "defaultLayout": "",
          "sortOrder": 1,
          "isLink": false,
          "linkUrl": "",
          "openBehavior": "currentTab",
          "audience": ""
        },
        {
          "uniqueId": "starter-vertical-1",
          "key": "documents",
          "label": "Documents",
          "iconName": "Document",
          "queryTemplate": "{searchTerms} IsDocument:1",
          "resultSourceId": "",
          "dataProviderId": "",
          "defaultLayout": "",
          "sortOrder": 2,
          "isLink": false,
          "linkUrl": "",
          "openBehavior": "currentTab",
          "audience": ""
        },
        {
          "uniqueId": "starter-vertical-2",
          "key": "pages",
          "label": "Pages",
          "iconName": "FileHTML",
          "queryTemplate": "{searchTerms} (contentclass:STS_ListItem_WebPageLibrary OR contentclass:STS_ListItem_PublishingPages)",
          "resultSourceId": "",
          "dataProviderId": "",
          "defaultLayout": "",
          "sortOrder": 3,
          "isLink": false,
          "linkUrl": "",
          "openBehavior": "currentTab",
          "audience": ""
        },
        {
          "uniqueId": "starter-vertical-3",
          "key": "sites",
          "label": "Sites",
          "iconName": "Globe",
          "queryTemplate": "{searchTerms} contentclass:STS_Site",
          "resultSourceId": "",
          "dataProviderId": "",
          "defaultLayout": "",
          "sortOrder": 4,
          "isLink": false,
          "linkUrl": "",
          "openBehavior": "currentTab",
          "audience": ""
        }
      ],
      "defaultVertical": "all",
      "showCounts": true,
      "hideEmptyVerticals": false,
      "tabStyle": "tabs"
    }
  }]
}
