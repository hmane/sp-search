{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx/client-side-web-part-manifest.schema.json",
  "id": "1836671c-a710-45b4-9a83-55c65344a3d5",
  "alias": "SpSearchResultsWebPart",
  "componentType": "WebPart",

  // The "*" signifies that the version should be taken from the package.json
  "version": "*",
  "manifestVersion": 2,

  // If true, the component can only be installed on sites where Custom Script is allowed.
  // Components that allow authors to embed arbitrary script code should set this to true.
  // https://support.office.com/en-us/article/Turn-scripting-capabilities-on-or-off-1f2c515f-5d7e-448a-9fd7-835da935584f
  "requiresCustomScript": false,
  "supportedHosts": ["SharePointWebPart", "TeamsPersonalApp", "TeamsTab", "SharePointFullPage"],
  "supportsThemeVariants": true,

  "preconfiguredEntries": [{
    "groupId": "5c03119e-3074-46fd-976b-c60198311f70",
    "group": { "default": "Advanced" },
    "title": { "default": "SP Search Results" },
    "description": { "default": "Search results with PnP-style starter defaults, multiple layouts, detail preview, and bulk actions" },
    "officeFabricIconFontName": "Search",
    "properties": {
      "searchContextId": "default",
      "searchScope": "currentsite",
      "queryTemplate": "{searchTerms}",
      "selectedProperties": "Title,Author,LastModifiedTime,FileType,Size,Path,SiteName",
      "selectedPropertiesCollection": [
        { "uniqueId": "starter-sp-0", "property": "Title", "alias": "Title" },
        { "uniqueId": "starter-sp-1", "property": "Author", "alias": "Author" },
        { "uniqueId": "starter-sp-2", "property": "LastModifiedTime", "alias": "Modified" },
        { "uniqueId": "starter-sp-3", "property": "FileType", "alias": "Type" },
        { "uniqueId": "starter-sp-4", "property": "Size", "alias": "Size" },
        { "uniqueId": "starter-sp-5", "property": "Path", "alias": "URL" },
        { "uniqueId": "starter-sp-6", "property": "SiteName", "alias": "Site" }
      ],
      "compactPropertiesCollection": [
        { "uniqueId": "starter-compact-0", "property": "Author", "alias": "Author" },
        { "uniqueId": "starter-compact-1", "property": "LastModifiedTime", "alias": "Modified" },
        { "uniqueId": "starter-compact-2", "property": "Size", "alias": "Size" },
        { "uniqueId": "starter-compact-3", "property": "FileType", "alias": "Type" }
      ],
      "gridPropertiesCollection": [
        { "uniqueId": "starter-grid-0", "property": "Author" },
        { "uniqueId": "starter-grid-1", "property": "LastModifiedTime" },
        { "uniqueId": "starter-grid-2", "property": "FileType" },
        { "uniqueId": "starter-grid-3", "property": "Size" },
        { "uniqueId": "starter-grid-4", "property": "Path" },
        { "uniqueId": "starter-grid-5", "property": "SiteName" }
      ],
      "refinementFilters": "",
      "refinementFiltersCollection": [],
      "pageSize": 10,
      "showPaging": true,
      "pageRange": 5,
      "layoutPreset": "general",
      "defaultLayout": "list",
      "showListLayout": true,
      "showCompactLayout": true,
      "showGridLayout": true,
      "showCardLayout": false,
      "showPeopleLayout": false,
      "showGalleryLayout": false,
      "sortablePropertiesCollection": [
        { "uniqueId": "starter-sort-0", "property": "LastModifiedTime", "label": "Date Modified", "direction": "Descending" },
        { "uniqueId": "starter-sort-1", "property": "Title", "label": "Title", "direction": "Ascending" }
      ],
      "showResultCount": true,
      "showSortDropdown": true,
      "showDeleteConfirmation": true,
      "enablePreviewPanel": true,
      "hideWebPartWhenNoResults": false,
      "titleDisplayMode": "wrap"
    }
  }]
}
