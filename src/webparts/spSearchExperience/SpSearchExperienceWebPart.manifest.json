{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx/client-side-web-part-manifest.schema.json",
  "id": "d05a3316-ceca-4ec6-b684-d44d5266fd68",
  "alias": "SpSearchExperienceWebPart",
  "componentType": "WebPart",

  "version": "*",
  "manifestVersion": 2,

  "requiresCustomScript": false,
  "supportedHosts": ["SharePointWebPart", "TeamsPersonalApp", "TeamsTab", "SharePointFullPage"],
  "supportsThemeVariants": true,
  "supportsFullBleed": true,

  "preconfiguredEntries": [{
    "groupId": "5c03119e-3074-46fd-976b-c60198311f70",
    "group": { "default": "Advanced" },
    "title": { "default": "SP Search Results + Filters" },
    "description": { "default": "Full-width search results and refiners in one coordinated web part" },
    "officeFabricIconFontName": "SearchAndApps",
    "properties": {
      "searchContextId": "default",
      "filtersPlacement": "right",
      "filtersWidth": 360,
      "searchScope": "currentsite",
      "queryTemplate": "{searchTerms}",
      "selectedPropertiesCollection": [
        { "uniqueId": "starter-sp-0", "property": "Title", "alias": "Title" },
        { "uniqueId": "starter-sp-1", "property": "Author", "alias": "Author" },
        { "uniqueId": "starter-sp-2", "property": "LastModifiedTime", "alias": "Modified" },
        { "uniqueId": "starter-sp-3", "property": "FileType", "alias": "Type" },
        { "uniqueId": "starter-sp-4", "property": "Size", "alias": "Size" },
        { "uniqueId": "starter-sp-5", "property": "Path", "alias": "URL" },
        { "uniqueId": "starter-sp-6", "property": "SiteName", "alias": "Site" }
      ],
      "compactPropertiesCollection": [
        { "uniqueId": "starter-compact-0", "property": "Author",           "alias": "Author",   "visibility": "defaultOn", "renderer": "" },
        { "uniqueId": "starter-compact-1", "property": "LastModifiedTime", "alias": "Modified", "visibility": "defaultOn", "renderer": "" },
        { "uniqueId": "starter-compact-2", "property": "Size",             "alias": "Size",     "visibility": "defaultOn", "renderer": "" },
        { "uniqueId": "starter-compact-3", "property": "FileType",         "alias": "Type",     "visibility": "defaultOn", "renderer": "" }
      ],
      "gridPropertiesCollection": [
        { "uniqueId": "starter-grid-0", "property": "Author",           "alias": "Author",   "visibility": "defaultOn", "renderer": "" },
        { "uniqueId": "starter-grid-1", "property": "LastModifiedTime", "alias": "Modified", "visibility": "defaultOn", "renderer": "" },
        { "uniqueId": "starter-grid-2", "property": "FileType",         "alias": "Type",     "visibility": "defaultOn", "renderer": "" },
        { "uniqueId": "starter-grid-3", "property": "Size",             "alias": "Size",     "visibility": "defaultOn", "renderer": "" },
        { "uniqueId": "starter-grid-4", "property": "Path",             "alias": "URL",      "visibility": "defaultOn", "renderer": "" },
        { "uniqueId": "starter-grid-5", "property": "SiteName",         "alias": "Site",     "visibility": "defaultOn", "renderer": "" }
      ],
      "refinementFiltersCollection": [],
      "pageSize": 10,
      "showPaging": true,
      "pageRange": 5,
      "layoutPreset": "general",
      "defaultLayout": "list",
      "showListLayout": true,
      "showCompactLayout": true,
      "showGridLayout": true,
      "showCardLayout": false,
      "showPeopleLayout": false,
      "showGalleryLayout": false,
      "sortablePropertiesCollection": [
        { "uniqueId": "starter-sort-0", "property": "LastModifiedTime", "label": "Date Modified", "direction": "Descending" },
        { "uniqueId": "starter-sort-1", "property": "Title", "label": "Title", "direction": "Ascending" }
      ],
      "showResultCount": true,
      "showSortDropdown": true,
      "showDeleteConfirmation": true,
      "enablePreviewPanel": true,
      "hideWebPartWhenNoResults": false,
      "emptyResultsMessage": "",
      "showColumnChooser": true,
      "titleDisplayMode": "wrap",
      "resultClickTarget": "panel",
      "documentLinkMode": "file",
      "listItemLinkMode": "displayForm",
      "resultSourceId": "",
      "collapseSpecification": "",
      "enableQueryRules": true,
      "trimDuplicates": true,
      "applyMode": "instant",
      "operatorBetweenFilters": "AND",
      "showClearAll": true,
      "enableVisualFilterBuilder": false,
      "audienceGroups": "",
      "filtersCollection": [
        {
          "uniqueId": "starter-filter-0",
          "managedProperty": "FileType",
          "displayName": "File type",
          "filterType": "checkbox",
          "operator": "OR",
          "maxValues": 10,
          "defaultExpanded": true,
          "showCount": true,
          "sortBy": "count",
          "sortDirection": "desc",
          "multiValues": true
        },
        {
          "uniqueId": "starter-filter-1",
          "managedProperty": "LastModifiedTime",
          "displayName": "Modified date",
          "filterType": "daterange",
          "operator": "OR",
          "maxValues": 1,
          "defaultExpanded": true,
          "showCount": false,
          "sortBy": "count",
          "sortDirection": "desc",
          "multiValues": false
        },
        {
          "uniqueId": "starter-filter-2",
          "managedProperty": "AuthorOWSUSER",
          "displayName": "Author",
          "filterType": "people",
          "operator": "OR",
          "maxValues": 10,
          "defaultExpanded": false,
          "showCount": false,
          "sortBy": "count",
          "sortDirection": "desc",
          "multiValues": true
        }
      ]
    }
  }]
}
